{% style %}
  .my_section {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 20px;
    text-align: center;
  }
{% endstyle %}

<h1 class="my_section">{{ section.settings.title }}</h1>

{% schema %}
{
  "name": "My Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Welcome to my store!"
    },
    {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color",
        "default": "#f41111"
    },
    {
    "type": "color",
    "id": "text_color",
    "label": "Text Color",
    "default": "#ffffff"
}
  ],

  "presets": [
    {
      "name": "My Setion"
    }
  ]
}
{% endschema %}
